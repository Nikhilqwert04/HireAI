{
  "name": "hireai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "client/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "npm run lint:fix --prefix client"
    ],
    "server/src/**/*.js": [
      "prettier --write",
      "npm run lint:fix --prefix server"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
